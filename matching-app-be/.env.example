# Database Configuration
MONGODB_URI=mongodb://localhost:27017/matching-app

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-make-it-very-long-and-random

# Twilio Configuration (Required for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional (single URL): also included in allowed origins list
FRONTEND_URL=
# Optional regex list (comma-separated), e.g. ^https://.*\\.vercel\\.app$
CORS_ORIGIN_REGEX=

# Debug Route Configuration
ENABLE_DEBUG_ROUTES=false
# Optional: if set, /api/debug/* requires this header: x-debug-token
DEBUG_API_TOKEN=

# Admin Configuration
# Required when database has no admin account:
# Comma-separated values are allowed, first value is used for bootstrap seed if no admin exists.
ADMIN_PHONE_NUMBERS=+819012345678
ADMIN_SEED_NAME=Administrator
ADMIN_SEED_GENDER=other
ADMIN_SEED_ADDRESS=Admin account

# Rate Limiting (optional)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
SMS_RATE_LIMIT_WINDOW=60
SMS_RATE_LIMIT_MAX=5
